# ============================================================
#  TagMemo-py 配置文件模板
#  复制为 config.env 后按需修改
# ============================================================

# [核心配置] Embedding API 凭证 (必需)
API_Key=sk-your-embedding-api-key
API_URL=https://api.openai.com/v1/embeddings
WhitelistEmbeddingModel=text-embedding-3-small
WhitelistEmbeddingModelMaxToken=8000
VECTORDB_DIMENSION=1536

# [核心配置] Chat API 凭证 (可选，不配置则以 Debug 模式运行，只返回记忆)
CHAT_API_KEY=sk-your-chat-api-key
CHAT_API_URL=https://api.openai.com/v1/chat/completions
CHAT_MODEL=gpt-4o-mini

# [服务配置]
PORT=3100
DEFAULT_TIMEZONE=Asia/Shanghai
# SYSTEM_PROMPT=              # 自定义系统提示词，留空使用默认值

# [知识库配置]
KNOWLEDGEBASE_ROOT_PATH=./data/dailynote
KNOWLEDGEBASE_STORE_PATH=./VectorStore
KNOWLEDGEBASE_FULL_SCAN_ON_STARTUP=true
KNOWLEDGEBASE_MAX_BATCH_SIZE=50
KNOWLEDGEBASE_BATCH_WINDOW_MS=2000
KNOWLEDGEBASE_INDEX_SAVE_DELAY=120000
KNOWLEDGEBASE_TAG_INDEX_SAVE_DELAY=300000

# [Tag 过滤配置]
TAG_BLACKLIST=
TAG_BLACKLIST_SUPER=
TAG_EXPAND_MAX_COUNT=30

# [文件过滤配置]
IGNORE_FOLDERS=
IGNORE_PREFIXES=
IGNORE_SUFFIXES=

# [语言补偿]
LANG_CONFIDENCE_GATING_ENABLED=true
LANG_PENALTY_UNKNOWN=0.05
LANG_PENALTY_CROSS_DOMAIN=0.1

# [Embedding 并发]
TAG_VECTORIZE_CONCURRENCY=5

# [查询缓存]
QUERY_CACHE_MAX_SIZE=200
QUERY_CACHE_TTL_MS=3600000

# [Rerank 重排序] (可选，填入 RERANK_API_URL 和 RERANK_API_KEY 后自动启用)
RERANK_API_URL=
RERANK_API_KEY=
RERANK_MODEL=jina-reranker-v2-base-multilingual
RERANK_MAX_TOKENS=8000
RERANK_K_MULTIPLIER=3
RERANK_TIMEOUT_MS=30000
